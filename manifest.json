{
  "manifest_version": 3,
  "name": "Classplus Lecture Logger",
  "version": "1.0.0",
  "description": "Automatically tracks and resumes your watched lectures on Classplus.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://web.classplusapp.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "View Watch History",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://web.classplusapp.com/*"],
      "js": ["content.js"]
    }
  ]
}